{
  "name": "@weilasdk/monorepo",
  "private": true,
  "scripts": {
    "build": "pnpm -r run build",
    "build:core": "pnpm --filter @weilasdk/core run build",
    "build:core:w": "pnpm --filter @weilasdk/core run build:watch",
    "build:ui": "pnpm --filter @weilasdk/ui run build",
    "dev": "pnpm --filter @weilasdk/playground-vue3 run dev",
    "dev:ui": "pnpm --filter @weilasdk/ui run dev",
    "story": "pnpm --filter @weilasdk/ui run story",
    "up": "pnpm dlx taze -Ir major",
    "build:story": "pnpm --filter @weilasdk/ui run build:story",
    "typecheck": "pnpm -r run typecheck",
    "lint": "oxlint --type-aware",
    "lint:fix": "oxlint --type-aware --fix",
    "fmt": "oxfmt",
    "fmt:check": "oxfmt --check",
    "preview": "pnpm --filter @weilasdk/playground-vue3 run build && pnpm --filter @weilasdk/playground-vue3 run preview"
  },
  "devDependencies": {
    "@antfu/ni": "catalog:",
    "lint-staged": "catalog:",
    "oxfmt": "catalog:",
    "oxlint": "catalog:",
    "oxlint-tsgolint": "catalog:",
    "simple-git-hooks": "catalog:",
    "taze": "catalog:"
  },
  "simple-git-hooks": {
    "pre-commit": "pnpm exec lint-staged"
  },
  "lint-staged": {
    "*": [
      "oxlint --type-aware",
      "oxfmt"
    ]
  },
  "engines": {
    "node": ">=18",
    "pnpm": ">=9"
  },
  "packageManager": "pnpm@10.33.0"
}

{
  "name": "@weilasdk/monorepo",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "build:core": "turbo run build --filter=@weilasdk/core",
    "build:core:w": "turbo run dev --filter=@weilasdk/core",
    "build:ui": "turbo run build --filter=@weilasdk/ui",
    "dev": "turbo run dev",
    "dev:ui": "turbo run dev --filter=@weilasdk/ui",
    "story": "turbo run story --filter=@weilasdk/ui",
    "up": "pnpm dlx taze -Ir major",
    "build:story": "turbo run build:story",
    "typecheck": "turbo run typecheck",
    "lint": "oxlint --type-aware",
    "lint:fix": "oxlint --type-aware --fix",
    "fmt": "oxfmt",
    "fmt:check": "oxfmt --check",
    "preview": "turbo run build --filter=@weilasdk/playground-vue3 && pnpm --filter @weilasdk/playground-vue3 run preview"
  },
  "devDependencies": {
    "@antfu/ni": "catalog:",
    "lint-staged": "catalog:",
    "oxfmt": "catalog:",
    "oxlint": "catalog:",
    "oxlint-tsgolint": "catalog:",
    "simple-git-hooks": "catalog:",
    "taze": "catalog:",
    "turbo": "^2.9.18"
  },
  "simple-git-hooks": {
    "pre-commit": "pnpm exec lint-staged"
  },
  "lint-staged": {
    "*": [
      "oxlint --type-aware",
      "oxfmt"
    ]
  },
  "engines": {
    "node": ">=18",
    "pnpm": ">=9"
  },
  "packageManager": "pnpm@10.33.0"
}

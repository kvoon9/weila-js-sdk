{
  "name": "@weilasdk/ui",
  "version": "0.0.1",
  "private": true,
  "description": "集成了 Weila SDK 的 UI 组件",
  "files": [
    "dist"
  ],
  "type": "module",
  "main": "dist/index.cjs",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./dist/index.css": "./dist/index.css"
  },
  "scripts": {
    "test": "vitest",
    "test:run": "vitest run",
    "test:ui": "vitest --ui",
    "build": "tsdown",
    "dev": "tsdown --watch",
    "typecheck": "vue-tsc --noEmit",
    "story": "storybook dev -p 6006",
    "build:story": "storybook build"
  },
  "dependencies": {
    "@weilasdk/core": "workspace:*"
  },
  "devDependencies": {
    "@iconify-json/carbon": "^1.2.20",
    "@iconify/tailwind4": "^1.2.3",
    "@storybook/addon-a11y": "^10.3.3",
    "@storybook/addon-docs": "^10.3.3",
    "@storybook/addon-onboarding": "^10.3.3",
    "@storybook/addon-vitest": "^10.3.3",
    "@storybook/vue3-vite": "^10.3.3",
    "@tailwindcss/postcss": "^4.2.2",
    "@vitejs/plugin-vue": "^6.0.5",
    "@vitest/browser-playwright": "^4.1.2",
    "@vue/test-utils": "^2.4.6",
    "autoprefixer": "^10.4.27",
    "jsdom": "^29.0.1",
    "playwright": "^1.58.2",
    "postcss": "^8.5.8",
    "postcss-cli": "^11.0.1",
    "storybook": "^10.3.3",
    "tailwindcss": "^4.2.2",
    "tsdown": "0.20.0-beta.3",
    "typescript": "^6.0.2",
    "unplugin-vue": "^7.1.1",
    "vitest": "^4.1.2",
    "vue": "^3.5.31",
    "vue-tsc": "^3.2.6"
  },
  "peerDependencies": {
    "vue": "^3.5.0"
  }
}

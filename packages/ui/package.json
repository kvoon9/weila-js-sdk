{
  "name": "@weilasdk/ui",
  "version": "0.0.1",
  "private": true,
  "description": "集成了 Weila SDK 的 UI 组件",
  "files": [
    "dist"
  ],
  "type": "module",
  "main": "dist/index.cjs",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./index.css": "./dist/index.css",
    "./dist/index.css": "./dist/index.css"
  },
  "scripts": {
    "test": "vitest",
    "test:run": "vitest run",
    "test:ui": "vitest --ui",
    "build": "tsdown",
    "dev": "tsdown --watch",
    "typecheck": "vue-tsc --noEmit",
    "story": "storybook dev -p 6006",
    "build:story": "storybook build"
  },
  "dependencies": {
    "@weilasdk/core": "workspace:*"
  },
  "devDependencies": {
    "@iconify-json/carbon": "catalog:",
    "@iconify/tailwind4": "catalog:",
    "@storybook/addon-a11y": "catalog:",
    "@storybook/addon-docs": "catalog:",
    "@storybook/addon-onboarding": "catalog:",
    "@storybook/addon-vitest": "catalog:",
    "@storybook/vue3-vite": "catalog:",
    "@tailwindcss/postcss": "catalog:",
    "@vitejs/plugin-vue": "catalog:",
    "@vitest/browser-playwright": "catalog:",
    "@vue/test-utils": "catalog:",
    "autoprefixer": "catalog:",
    "jsdom": "catalog:",
    "playwright": "catalog:",
    "postcss": "catalog:",
    "postcss-cli": "catalog:",
    "storybook": "catalog:",
    "tailwindcss": "catalog:",
    "tsdown": "catalog:",
    "typescript": "^6.0.2",
    "unplugin-vue": "catalog:",
    "vitest": "catalog:",
    "vue": "catalog:",
    "vue-tsc": "catalog:"
  },
  "peerDependencies": {
    "floating-vue": "^5.1.1",
    "vue": "^3.5.0"
  }
}

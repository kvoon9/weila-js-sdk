{
  "name": "@weilasdk/core",
  "version": "1.1.2",
  "private": true,
  "description": "微喇网页SDK",
  "keywords": [],
  "license": "VOIS",
  "author": "Jack Chen",
  "files": [
    "dist"
  ],
  "main": "dist/weilasdk.mjs",
  "module": "dist/weilasdk.mjs",
  "types": "dist/weilasdk.d.ts",
  "exports": {
    ".": {
      "types": "./dist/weilasdk.d.ts",
      "import": "./dist/weilasdk.mjs"
    },
    "./data": {
      "types": "./dist/weilasdk_data.d.ts",
      "import": "./dist/weilasdk_data.mjs"
    },
    "./log": {
      "types": "./dist/weilasdk_log.d.ts",
      "import": "./dist/weilasdk_log.mjs"
    }
  },
  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 1",
    "build": "webpack --config webpack.config.js --progress --node-env production && tsc-alias -p tsconfig.json",
    "build:dev": "webpack --config webpack.config.js --progress --node-env development",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "ali-oss": "catalog:core",
    "crypto-js": "catalog:core",
    "debug": "catalog:core",
    "dexie": "catalog:core",
    "gently-copy": "catalog:core",
    "long": "catalog:core",
    "pack": "catalog:core",
    "protobufjs": "catalog:core",
    "tiny-emitter": "catalog:core",
    "tiny-pinyin": "catalog:core",
    "xstate": "catalog:core"
  },
  "devDependencies": {
    "@types/ali-oss": "catalog:core",
    "@types/debug": "catalog:core",
    "@types/node": "catalog:core",
    "copy-webpack-plugin": "catalog:core",
    "dotenv-webpack": "catalog:core",
    "file-loader": "catalog:core",
    "ts-loader": "catalog:core",
    "tsc-alias": "catalog:core",
    "typescript": "^5.9.3",
    "url-loader": "catalog:core",
    "webpack": "catalog:core",
    "webpack-cli": "catalog:core",
    "worker-loader": "catalog:core",
    "worklet-loader": "catalog:core"
  }
}
